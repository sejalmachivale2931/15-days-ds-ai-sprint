    "class Student:\n",
    "    def __init__(self,name,marks):\n",
    "        self.name = name\n",
    "        self.marks = marks\n",
    "    def show(self):\n",
    "        print(self.name, \" : \", self.marks)\n",
    "s1 = Student(\"Sejal\",85)\n",
    "s1.show()"
   ]
